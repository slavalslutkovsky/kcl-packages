{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "plugins": [
    "./tools/nx-kcl/src/index.ts"
  ],
  "targetDefaults": {
    "build": {
      "cache": true
    },
    "test": {
      "cache": true
    },
    "lint": {
      "cache": true
    }
  },
  "release": {
    "projects": [
      "tag:lang:kcl",
      "!tag:area:providers"
    ],
    "projectsRelationship": "independent",
    "registry": "docker.io/yurikrupnik",
    "version": {
      "versionActions": "./tools/nx-kcl/src/release/version-actions.ts",
      "fallbackCurrentVersionResolver": "disk"
    },
    "changelog": {
      "projectChangelogs": true,
      "automaticFromRef": true
    },
    "git": {
      "commit": true,
      "commitMessage": "chore(release): {projectName}@{version}",
      "tag": true
    },
    "releaseTag": {
      "pattern": "{projectName}@{version}"
    }
  },
  "analytics": true
}